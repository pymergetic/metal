# pymergetic-metal Zephyr engine — shared Kconfig

mainmenu "Pymergetic Metal Runtime (Zephyr)"

source "Kconfig.zephyr"

config PM_METAL_SYS_HANDOFF_VFS_ROOT
	string "Bootstrap handoff path (host and guest)"
	default "/sys/pm"
	help
	  Path where lower publishes bootstrap (…/bootstrap). Same path mods
	  open as PM_METAL_SYS_BOOTSTRAP_PATH when the host tree is WASI-preopened as /.

config PM_METAL_VERIFY_MOD_SMOKE
	bool "Stage and run mod-smoke.wasm after boot (verify)"
	default n
	help
	  Embed build/mods/mod-smoke.wasm, write it to the host VFS, and run it
	  via wasm_host after orchestrator boot. Used by verify-mod scripts.

config PM_METAL_ARENA_ALIGN
	int "Arena page alignment (bytes)"
	default 4096
	help
	  Page alignment for arena_budget and WAMR pool mapping on targets
	  without CONFIG_MMU_PAGE_SIZE (e.g. native_sim).
