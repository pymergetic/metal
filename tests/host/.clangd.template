# Host regressions use Linux glibc. Generated by ./scripts/setup ide.
# CDB entries (also from setup ide) supply the base command; Remove strips
# freestanding/WASI -I that the repo-root .clangd merges in globally.
CompileFlags:
  Compiler: /usr/bin/clang
  Remove:
    - -I@@ROOT@@/src/pymergetic/metal/runtime/mem/host_stubs
    - -I@@ROOT@@/src/pymergetic/metal/guest/wamr
    - -I@@ROOT@@/external/wamr/core/shared/platform/include
    - -I@@ROOT@@/external/wamr/core/iwasm/libraries/libc-wasi/sandboxed-system-primitives/include
    - --target=wasm32-wasip1
    - --sysroot=@@ROOT@@/.tools/wasi-sdk/share/wasi-sysroot
  Add:
    - --target=x86_64-linux-gnu
    - -std=c11
    - -D_GNU_SOURCE
    - -I@@ROOT@@/external/tlsf
    - -I@@ROOT@@/include
