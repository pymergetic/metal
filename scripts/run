#!/usr/bin/env bash
# Interactive runners (not verify).
# Usage: scripts/run efi|bios [--vnc N] [--no-vnc]
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PORT="${ROOT}/scripts/run.d/port"

usage() {
	cat >&2 <<'EOF'
usage: scripts/run efi|bios [--vnc N] [--no-vnc]

  efi  — QEMU+OVMF, fresh ESP every launch, serial on stdio
  bios — QEMU+SeaBIOS Multiboot2 -kernel, serial on stdio
EOF
	exit 1
}

[[ $# -ge 1 ]] || usage
plat="$1"
shift

case "${plat}" in
-h | --help | help) usage ;;
efi)
	exec "${PORT}/efi/default.sh" "$@"
	;;
bios)
	exec "${PORT}/bios/default.sh" "$@"
	;;
*) usage ;;
esac
