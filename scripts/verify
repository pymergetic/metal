#!/usr/bin/env bash
# Verify interface — EFI + BIOS freestanding smoke.
# Usage: scripts/verify efi|bios|all
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PORT="${ROOT}/scripts/verify.d/port"

usage() {
	cat >&2 <<'EOF'
usage: scripts/verify efi|bios|all|drift|host

  efi   — QEMU+OVMF smoke (boot tree + metal-boot: ready)
  bios  — QEMU+SeaBIOS Multiboot2 smoke (same markers, handoff)
  all   — drift check, host regressions, then efi, then bios
  drift — BIOS/EFI dual-tree drift gate (no QEMU)
  host  — host-side defect regressions (no QEMU; ASan when available)
EOF
	exit 1
}

[[ $# -ge 1 ]] || usage
plat="$1"
shift
[[ $# -eq 0 ]] || usage

case "${plat}" in
-h | --help | help) usage ;;
drift)
	exec "${PORT}/dual-tree-drift.sh"
	;;
host)
	exec "${ROOT}/scripts/verify.d/host/default.sh"
	;;
efi)
	exec "${PORT}/efi/default.sh"
	;;
bios)
	exec "${PORT}/bios/default.sh"
	;;
all)
	"${PORT}/dual-tree-drift.sh"
	"${ROOT}/scripts/verify.d/host/default.sh"
	"${PORT}/efi/default.sh"
	exec "${PORT}/bios/default.sh"
	;;
*) usage ;;
esac
