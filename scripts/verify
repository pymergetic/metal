#!/usr/bin/env bash
# Verify interface — EFI freestanding smoke (hosted ports archived).
# Usage: scripts/verify efi
#        scripts/verify all
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PORT="${ROOT}/scripts/verify.d/port"

usage() {
	cat >&2 <<'EOF'
usage: scripts/verify efi
       scripts/verify all

  efi / all — QEMU+OVMF smoke (banner + Total memory + ok marker)

Hosted linux/zephyr/nuttx verify lives on archive/multi-host-linux-zephyr-nuttx.
EOF
	exit 1
}

[[ $# -ge 1 ]] || usage
plat="$1"
shift
[[ $# -eq 0 ]] || usage

case "${plat}" in
-h | --help | help) usage ;;
efi | all)
	exec "${PORT}/efi/default.sh"
	;;
*) usage ;;
esac
