#!/usr/bin/env bash
# Setup — EFI freestanding deps (hosted west/nuttx setup archived).
# Usage: scripts/setup <name>
#        scripts/setup all
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
DEPS="${ROOT}/scripts/setup.d/deps"
PORT="${ROOT}/scripts/setup.d/port"
# shellcheck disable=SC1091
source "${ROOT}/scripts/lib/run-steps.sh"

usage() {
	cat >&2 <<'EOF'
usage: scripts/setup <name>
       scripts/setup all

Deps (setup.d/deps/):
  edk2   — Tianocore EDK2 + local nasm (required for metal.efi)
  tools  wamr  wamrc  lwip  lz4  microtar  monocypher  mbedtls  nghttp2  curl  net
  cpython  ide  doomgeneric

  wamrc — prebuilt AOT compiler (.tools/wamrc); optional until a mod opts into .aot

  lwip — TCP/IP stack for EFI virtio-net (NO_SYS raw API)
  net  — chains monocypher + mbedtls + nghttp2 + curl

Platform:
  efi   — OVMF / toolchain notes

  all   — edk2 + efi (+ optional guest deps)
EOF
	exit 1
}

[[ $# -ge 1 ]] || usage
name="$1"
shift

case "${name}" in
-h | --help | help) usage ;;
all)
	[[ $# -eq 0 ]] || usage
	pm_run_steps "${ROOT}/scripts/setup" \
		"edk2" \
		"efi"
	exit $?
	;;
efi)
	exec "${PORT}/efi/default.sh" "$@"
	;;
*)
	script="${DEPS}/${name}.sh"
	if [[ ! -f "${script}" ]]; then
		echo "unknown setup name: ${name}" >&2
		usage
	fi
	exec "${script}" "$@"
	;;
esac
