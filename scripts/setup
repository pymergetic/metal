#!/usr/bin/env bash
# Setup — EFI freestanding deps (hosted west/nuttx setup archived).
# Usage: scripts/setup <name>
#        scripts/setup all
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
DEPS="${ROOT}/scripts/setup.d/deps"
PORT="${ROOT}/scripts/setup.d/port"
# shellcheck disable=SC1091
source "${ROOT}/scripts/lib/run-steps.sh"

usage() {
	cat >&2 <<'EOF'
usage: scripts/setup <name>
       scripts/setup all

Deps (setup.d/deps/):
  tools  wamr  lz4  microtar  monocypher  mbedtls  nghttp2  curl  net
  cpython  ide

  net  — chains monocypher + mbedtls + nghttp2 + curl

Platform:
  efi   — toolchain / OVMF notes for freestanding Metal

  all   — tools + wamr + lz4 + microtar + net + cpython + efi + ide
EOF
	exit 1
}

[[ $# -ge 1 ]] || usage
name="$1"
shift

case "${name}" in
-h | --help | help) usage ;;
all)
	[[ $# -eq 0 ]] || usage
	pm_run_steps "${ROOT}/scripts/setup" \
		"tools" \
		"wamr" \
		"lz4" \
		"microtar" \
		"net" \
		"cpython" \
		"efi" \
		"ide"
	exit $?
	;;
efi)
	exec "${PORT}/efi/default.sh" "$@"
	;;
*)
	script="${DEPS}/${name}.sh"
	if [[ ! -f "${script}" ]]; then
		echo "unknown setup name: ${name}" >&2
		usage
	fi
	exec "${script}" "$@"
	;;
esac
