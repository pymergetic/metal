#!/usr/bin/env bash
# Shared build interface:
#   build.d/guest/           — compile tests + cpython; package via lib/guest-package.sh
#   build.d/port/<platform>/ — host/firmware builds
# Usage: scripts/build <platform> [<subplatform>] [command]
#        scripts/build all
#        scripts/build <platform> all
# Omitted subplatform → none.
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PORT="${ROOT}/scripts/build.d/port"
GUEST="${ROOT}/scripts/build.d/guest"
# shellcheck disable=SC1091
source "${ROOT}/scripts/lib/run-steps.sh"

usage() {
	cat >&2 <<'EOF'
usage: scripts/build <platform> [<subplatform>] [command]
       scripts/build all
       scripts/build <platform> all

  subplatform defaults to none when omitted.

  platform / subplatform:
    linux   none | all
    zephyr  qemu | native-sim | none | all
    nuttx   sim | qemu | all
    efi     none | all    (freestanding UEFI + virtio — scaffold)
    mod     none          (guest wasm tests)
    cpython none          (python.wasm)
    all                   — guest + every host/firmware target (AI full run)

  optional command:
    zephyr [none] embed

  zephyr all — embed + qemu + native-sim
  nuttx all  — sim + qemu
  linux all  — linux
  efi all    — efi

Examples:
  scripts/build all
  scripts/build mod
  scripts/build zephyr all
  scripts/build zephyr qemu
  scripts/build nuttx sim
  scripts/build nuttx qemu
  scripts/build efi
EOF
	exit 1
}

run() {
	local script="$1"
	shift
	if [[ ! -f "${script}" ]]; then
		echo "missing ${script}" >&2
		exit 1
	fi
	exec "${script}" "$@"
}

[[ $# -ge 1 ]] || usage
plat="$1"
shift

case "${plat}" in
-h | --help | help) usage ;;
all)
	[[ $# -eq 0 ]] || usage
	pm_run_steps "${ROOT}/scripts/build" \
		"mod" \
		"cpython" \
		"linux" \
		"zephyr embed" \
		"zephyr qemu" \
		"zephyr native-sim" \
		"nuttx sim" \
		"nuttx qemu"
	exit $?
	;;
esac

sub="none"
cmd=""

if [[ $# -ge 1 ]]; then
	case "${plat}" in
	linux | mod | cpython | efi)
		if [[ "$1" == "all" ]]; then
			[[ $# -eq 1 ]] || usage
			case "${plat}" in
			linux) pm_run_steps "${ROOT}/scripts/build" "linux" ;;
			mod) pm_run_steps "${ROOT}/scripts/build" "mod" ;;
			cpython) pm_run_steps "${ROOT}/scripts/build" "cpython" ;;
			efi) pm_run_steps "${ROOT}/scripts/build" "efi" ;;
			esac
			exit $?
		elif [[ "$1" == "none" ]]; then
			shift
			[[ $# -eq 0 ]] || usage
		else
			usage
		fi
		;;
	zephyr)
		case "$1" in
		all)
			[[ $# -eq 1 ]] || usage
			pm_run_steps "${ROOT}/scripts/build" \
				"zephyr embed" \
				"zephyr qemu" \
				"zephyr native-sim"
			exit $?
			;;
		qemu | native-sim)
			sub="$1"
			shift
			[[ $# -eq 0 ]] || usage
			;;
		none)
			sub="none"
			shift
			cmd="${1:-}"
			[[ $# -gt 0 ]] && shift || true
			[[ $# -eq 0 ]] || usage
			;;
		embed)
			sub="none"
			cmd="embed"
			shift
			[[ $# -eq 0 ]] || usage
			;;
		*) usage ;;
		esac
		;;
	nuttx)
		case "$1" in
		all)
			[[ $# -eq 1 ]] || usage
			pm_run_steps "${ROOT}/scripts/build" "nuttx sim" "nuttx qemu"
			exit $?
			;;
		sim | qemu)
			sub="$1"
			shift
			[[ $# -eq 0 ]] || usage
			;;
		*) usage ;;
		esac
		;;
	*) usage ;;
	esac
fi

case "${plat}" in
linux)
	[[ "${sub}" == "none" && -z "${cmd}" ]] || usage
	run "${PORT}/linux/default.sh"
	;;
efi)
	[[ "${sub}" == "none" && -z "${cmd}" ]] || usage
	run "${PORT}/efi/default.sh"
	;;
mod)
	[[ "${sub}" == "none" && -z "${cmd}" ]] || usage
	run "${GUEST}/mod.sh"
	;;
cpython)
	[[ "${sub}" == "none" && -z "${cmd}" ]] || usage
	run "${GUEST}/cpython.sh"
	;;
nuttx)
	case "${sub}" in
	sim)
		[[ -z "${cmd}" ]] || usage
		run "${PORT}/nuttx/sim.sh"
		;;
	qemu)
		[[ -z "${cmd}" ]] || usage
		run "${PORT}/nuttx/qemu.sh"
		;;
	*) usage ;;
	esac
	;;
zephyr)
	case "${sub}" in
	qemu)
		[[ -z "${cmd}" ]] || usage
		run "${PORT}/zephyr/qemu.sh"
		;;
	native-sim)
		[[ -z "${cmd}" ]] || usage
		run "${PORT}/zephyr/native-sim.sh"
		;;
	none)
		case "${cmd}" in
		embed) run "${PORT}/zephyr/embed.sh" ;;
		*) usage ;;
		esac
		;;
	*) usage ;;
	esac
	;;
*) usage ;;
esac
