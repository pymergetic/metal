#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"

if [[ ! -f "${ROOT}/third_party/zephyr/west.yml" ]]; then
	echo "Missing ${ROOT}/third_party/zephyr/west.yml" >&2
	echo "Run: git submodule update --init third_party/zephyr" >&2
	exit 1
fi

if [[ ! -x "${ROOT}/.venv/bin/west" ]]; then
	python3 -m venv "${ROOT}/.venv"
	"${ROOT}/.venv/bin/pip" install -q -r "${ROOT}/scripts/requirements.txt"
fi

export PATH="${ROOT}/.venv/bin:${PATH}"
cd "${ROOT}"
west update
echo "Done."
