# Fragment merged onto qemu-intel64:nsh for Metal (scripts/build nuttx qemu).
# Lines may be KEY=val or "# KEY is not set" (unset).
CONFIG_PYMERGETIC_METAL=y
CONFIG_PYMERGETIC_METAL_STACKSIZE=65536
CONFIG_DEV_PIPE_SIZE=1024
CONFIG_PSEUDOFS_SOFTLINKS=y
CONFIG_LIBC_MAX_EXITFUNS=4
CONFIG_TLS_NELEM=4
CONFIG_PTHREAD_MUTEX_TYPES=y
CONFIG_FS_LARGEFILE=y
CONFIG_SCHED_WAITPID=y
# Default 80 truncates pm_metal CLI; default 7 is too small for python argv.
CONFIG_LINE_MAX=1024
CONFIG_NSH_MAXARGUMENTS=24
# Scripted serial: match sim (readline, not CLE). Upstream nsh uses CLE +
# USEC_PER_TICK=1 which makes char-echo verify crawl under QEMU.
CONFIG_NSH_READLINE=y
# CONFIG_NSH_CLE is not set
CONFIG_SYSTEM_READLINE=y
# CONFIG_SYSTEM_CLE is not set
# CONFIG_NSH_DISABLE_ECHOBACK is not set
CONFIG_USEC_PER_TICK=10000
# Upstream RXBUFSIZE=16 drops long nsh lines (pm_metal argv) on the 16550 FIFO.
CONFIG_16550_UART0_RXBUFSIZE=256
CONFIG_16550_UART0_TXBUFSIZE=256
# Writable FS for Stage A hostdir + pkg_apply_all (~90 MiB guest packages).
# Without this, /tmp is a tiny pseudofs node and populate write fails.
CONFIG_FS_TMPFS=y
CONFIG_FS_TMPFS_BLOCKSIZE=512
# Plenty of FDs for python stdlib extract + WASI.
CONFIG_NFILE_DESCRIPTORS_PER_BLOCK=32
CONFIG_NPTHREAD_KEYS=32
# WAMR WASI allocates guest fds via random_uniform → open("/dev/urandom").
CONFIG_DEV_URANDOM=y
# Upstream nsh is 256 MiB — too small for python.wasm server pools via malloc.
# 1 GiB board RAM; QEMU is launched with -m 2G.
CONFIG_RAM_SIZE=1073741824
# Drop unused sample/test apps that bloat the image.
# CONFIG_EXAMPLES_HELLO is not set
# CONFIG_TESTING_OSTEST is not set
# Socket symbols (recv/send) for Metal port/tcp.c — loopback only; t31 HTTPS
# still deferred (no mbedTLS/curl on this board yet).
CONFIG_NET=y
CONFIG_NET_IPv4=y
CONFIG_NET_TCP=y
CONFIG_NET_UDP=y
CONFIG_NET_SOCKOPTS=y
CONFIG_SCHED_WORKQUEUE=y
CONFIG_SCHED_LPWORK=y
