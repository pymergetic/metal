# Fragment merged onto sim:nsh for Metal bring-up (scripts/build nuttx sim).
# Do NOT set CONFIG_FS_TMPFS here — that is NuttX's own tmpfs driver and needs
# a full set of FS_TMPFS_* knobs; Metal's mount/tmpfs bind uses mkdtemp under
# plain /tmp instead.
#
# Lines may be KEY=val or "# KEY is not set" (unset).
CONFIG_PYMERGETIC_METAL=y
CONFIG_PYMERGETIC_METAL_STACKSIZE=65536
CONFIG_DEV_PIPE_SIZE=1024
CONFIG_PSEUDOFS_SOFTLINKS=y
CONFIG_LIBC_MAX_EXITFUNS=4
CONFIG_TLS_NELEM=4
CONFIG_PTHREAD_MUTEX_TYPES=y
CONFIG_FS_LARGEFILE=y
CONFIG_SCHED_WAITPID=y
# Default 80 truncates pm_metal CLI (memory + rootfs + mod path).
CONFIG_LINE_MAX=1024
# Default 7 is too small for python guest CLI (--mount/--env/-- argv).
CONFIG_NSH_MAXARGUMENTS=24
# WAMR WASI allocates guest fds via random_uniform → open("/dev/urandom").
# Without this, path_open succeeds on the host fd then fails with ENOENT.
CONFIG_DEV_URANDOM=y
# Upstream sim:nsh turns on toolchain gcov for the whole tree. Metal verify
# does not consume .gcda, and rebuilt .o checksums vs stale .gcda spam
# libgcov "different checksum" on every poweroff — leave coverage off here.
CONFIG_COVERAGE_NONE=y
# CONFIG_COVERAGE_TOOLCHAIN is not set
# CONFIG_COVERAGE_ALL is not set
# CONFIG_SYSTEM_GCOV is not set
# Metal net/{dns,udp,http} on sim: host libc + host libcurl
# (port/host_net_adapt.c on the final nuttx link). No CONFIG_NET / usrsock —
# host_usrsock_loop is never polled in this NuttX tree.
