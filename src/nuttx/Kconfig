#
# Pymergetic Metal runtime (WAMR host) for NuttX.
# See src/nuttx/README.md.
#

menuconfig PYMERGETIC_METAL
	bool "Pymergetic Metal WASM runtime"
	default n
	depends on LIBC
	---help---
		Long-lived Metal host: load/run wasm32-wasip1 mods via WAMR.
		First bring-up target is the NuttX sim board (hostdir rootfs).
		Build with NuttX CMake — see scripts/build nuttx sim.

if PYMERGETIC_METAL

config PYMERGETIC_METAL_PRIORITY
	int "Metal app priority"
	default 100

config PYMERGETIC_METAL_STACKSIZE
	int "Metal app stack size"
	default 65536

config PYMERGETIC_METAL_PROGNAME
	string "Metal program name"
	default "pm_metal"

endif # PYMERGETIC_METAL
