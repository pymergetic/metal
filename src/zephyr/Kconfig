mainmenu "Pymergetic Metal (Zephyr)"

source "Kconfig.zephyr"

config PM_METAL_ARENA_ALIGN
	int "Metal arena alignment (bytes)"
	default 4096
	help
	  Page/alignment used when rounding arena_budget on targets without
	  CONFIG_MMU_PAGE_SIZE.

config PM_METAL_VERIFY_MODS
	bool "Embed and run Zephyr verify mods at boot"
	default n
	help
	  When enabled, main embeds the Zephyr verify wasm set (T0/T1, tmpfs,
	  populate, proc, multimod, process), stages them under the FAT root,
	  and runs pm_metal_app_run_scripted batches.

config PM_METAL_STATIC_POOL_BYTES
	int "Static Metal pool region (non-MMU targets)"
	default 16777216
	help
	  BSS-backed region carved into kheap + bytecode pools when CONFIG_MMU
	  is off (e.g. native_sim). Ignored when MMU mapping is used.
