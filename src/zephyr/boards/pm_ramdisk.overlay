/ {
	/* FAT volume is /RAM: (ELM FatFs); mounted from main after mkfs. */

	ramdisk0 {
		compatible = "zephyr,ram-disk";
		disk-name = "RAM";
		sector-size = <512>;
		sector-count = <16384>; /* 8 MiB — room for embedded verify mods */
	};

	ramdisk1 {
		compatible = "zephyr,ram-disk";
		disk-name = "scratch";
		sector-size = <512>;
		sector-count = <2048>;
	};

	ramdisk2 {
		compatible = "zephyr,ram-disk";
		disk-name = "scratch2";
		sector-size = <512>;
		sector-count = <2048>;
	};

	ramdisk3 {
		compatible = "zephyr,ram-disk";
		disk-name = "other";
		sector-size = <512>;
		sector-count = <2048>;
	};
};
