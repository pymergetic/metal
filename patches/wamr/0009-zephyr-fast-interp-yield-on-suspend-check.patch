# Same Metal Zephyr yield / cur_exception fallback as 0005, for the *fast*
# interpreter. Without this, WAMR_BUILD_FAST_INTERP=1 lets t5_spin starve
# native_sim main (no k_yield on BR) so process kill() never runs.
# Applied by scripts/setup wamr. See docs/SOURCETREE.md "Vendoring".
diff --git a/core/iwasm/interpreter/wasm_interp_fast.c b/core/iwasm/interpreter/wasm_interp_fast.c
index 1c744f9a..e5abeb1b 100644
--- a/core/iwasm/interpreter/wasm_interp_fast.c
+++ b/core/iwasm/interpreter/wasm_interp_fast.c
@@ -1379,6 +1379,12 @@ wasm_interp_call_func_import(WASMModuleInstance *module_inst,
 #endif
 
 #if WASM_ENABLE_THREAD_MGR != 0
+#if defined(BH_PLATFORM_ZEPHYR)
+#include <zephyr/kernel.h>
+#define PM_METAL_WAMR_YIELD_FAST() k_yield()
+#else
+#define PM_METAL_WAMR_YIELD_FAST() ((void)0)
+#endif
 #define CHECK_SUSPEND_FLAGS()                               \
     do {                                                    \
         WASM_SUSPEND_FLAGS_LOCK(exec_env->wait_lock);       \
@@ -1388,8 +1394,17 @@ wasm_interp_call_func_import(WASMModuleInstance *module_inst,
             WASM_SUSPEND_FLAGS_UNLOCK(exec_env->wait_lock); \
             return;                                         \
         }                                                   \
+        /* pymergetic/metal: best-effort unlocked read of   \
+         * module->cur_exception — same as classic 0005. */ \
+        if (module->cur_exception[0] != '\0') {             \
+            WASM_SUSPEND_FLAGS_UNLOCK(exec_env->wait_lock); \
+            return;                                         \
+        }                                                   \
         /* TODO: support suspend and breakpoint */          \
         WASM_SUSPEND_FLAGS_UNLOCK(exec_env->wait_lock);     \
+        /* pymergetic/metal: let controller run kill/wait   \
+         * on native_sim while a guest is in a hot loop. */ \
+        PM_METAL_WAMR_YIELD_FAST();                         \
     } while (0)
 #endif
 
