Avoid Zephyr header macro clashes and GNU ld executable-stack warning when
building WAMR: undef GB/MIN before redefining (sys/util.h), and emit
.note.GNU-stack from invokeNative_em64.s and invokeNative_em64_simd.s.

The GNU-stack note is always emitted (no #if): CMake compiles these as
plain ASM (.s), so the C preprocessor does not run and a #if guard would
be left as literal text for gas. Applied by scripts/setup wamr.

diff -ruN a/core/iwasm/common/arch/invokeNative_em64.s b/core/iwasm/common/arch/invokeNative_em64.s
--- a/core/iwasm/common/arch/invokeNative_em64.s	2026-07-16 15:45:27.612434909 +0000
+++ b/core/iwasm/common/arch/invokeNative_em64.s	2026-07-16 15:45:27.626434876 +0000
@@ -62,3 +62,8 @@
     leave
     ret
 
+/* Mark non-executable stack — without this, GNU ld warns and links an
+ * executable stack (deprecated). Same note as typical glibc asm objects.
+ * Always emitted: gas does not preprocess .s, so #if would be left literal. */
+    .section .note.GNU-stack,"",@progbits
+
diff -ruN a/core/iwasm/common/arch/invokeNative_em64_simd.s b/core/iwasm/common/arch/invokeNative_em64_simd.s
--- a/core/iwasm/common/arch/invokeNative_em64_simd.s	2026-07-16 15:45:27.615434902 +0000
+++ b/core/iwasm/common/arch/invokeNative_em64_simd.s	2026-07-16 15:45:27.628434872 +0000
@@ -62,3 +62,8 @@
     leave
     ret
 
+/* Mark non-executable stack — without this, GNU ld warns and links an
+ * executable stack (deprecated). Same note as typical glibc asm objects.
+ * Always emitted: gas does not preprocess .s, so #if would be left literal. */
+    .section .note.GNU-stack,"",@progbits
+
diff -ruN a/core/iwasm/libraries/lib-wasi-threads/tid_allocator.c b/core/iwasm/libraries/lib-wasi-threads/tid_allocator.c
--- a/core/iwasm/libraries/lib-wasi-threads/tid_allocator.c	2026-07-16 15:45:27.618434895 +0000
+++ b/core/iwasm/libraries/lib-wasi-threads/tid_allocator.c	2026-07-16 15:45:27.630434867 +0000
@@ -8,6 +8,10 @@
 #include "bh_log.h"
 
 bh_static_assert(TID_MIN <= TID_MAX);
+/* Avoid clash with Zephyr sys/util.h's MIN() when building for zephyr. */
+#ifdef MIN
+#undef MIN
+#endif
 #define MIN(a, b) (((a) < (b)) ? (a) : (b))
 
 bool
diff -ruN a/core/shared/mem-alloc/ems/ems_gc.c b/core/shared/mem-alloc/ems/ems_gc.c
--- a/core/shared/mem-alloc/ems/ems_gc.c	2026-07-16 15:45:27.621434888 +0000
+++ b/core/shared/mem-alloc/ems/ems_gc.c	2026-07-16 15:45:27.632434862 +0000
@@ -6,6 +6,10 @@
 #include "ems_gc.h"
 #include "ems_gc_internal.h"
 
+/* Avoid clash with Zephyr sys/util.h's GB(x) macro when building for zephyr. */
+#ifdef GB
+#undef GB
+#endif
 #define GB (1 << 30UL)
 
 #define MARK_NODE_OBJ_CNT 256
