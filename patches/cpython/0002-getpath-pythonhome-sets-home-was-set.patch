+    # ._pth / in-tree build-layout probes (same as Py_SetPythonHome).
+    # Without this, wasi embeds that only surface ENV_PYTHONHOME inside
+    # getpath still open python.wasm._pth / pybuilddir.txt / Modules/*.
+    home_was_set = True
 
 
