# When PYTHONHOME is taken from the environment inside getpath, also set
# home_was_set (same as Py_SetPythonHome / PyConfig.home). Without this, WASI
# embeds that only surface ENV_PYTHONHOME still probe ._pth / pybuilddir /
# Modules / pyvenv.cfg, and a present pyvenv.cfg rewrites prefix to
# dirname(dirname(executable)) — fighting PYTHONHOME=/.
# No Metal src/ workaround: path calc lives entirely in frozen getpath.
# Apply via scripts/setup cpython only.
diff --git a/Modules/getpath.py b/Modules/getpath.py
