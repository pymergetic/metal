Rename microtar's static stdio backends away from file_{read,write,seek,close}.
On NuttX, #include <stdio.h> pulls in nuttx/fs/fs.h which declares those
exact names as VFS APIs — conflicting types with these static helpers even
though they are file-local. No src/-side workaround: the names live inside
vendored microtar.c. Harmless on linux/zephyr. Applied by
scripts/setup-microtar.sh. See docs/SOURCETREE.md "Vendoring".

diff --git a/src/microtar.c b/src/microtar.c
index e5d0dc6..8bdf736 100644
--- a/src/microtar.c
+++ b/src/microtar.c
@@ -160,22 +160,22 @@ const char* mtar_strerror(int err) {
 }
 
 
-static int file_write(mtar_t *tar, const void *data, unsigned size) {
+static int mtar_stdio_write(mtar_t *tar, const void *data, unsigned size) {
   unsigned res = fwrite(data, 1, size, tar->stream);
   return (res == size) ? MTAR_ESUCCESS : MTAR_EWRITEFAIL;
 }
 
-static int file_read(mtar_t *tar, void *data, unsigned size) {
+static int mtar_stdio_read(mtar_t *tar, void *data, unsigned size) {
   unsigned res = fread(data, 1, size, tar->stream);
   return (res == size) ? MTAR_ESUCCESS : MTAR_EREADFAIL;
 }
 
-static int file_seek(mtar_t *tar, unsigned offset) {
+static int mtar_stdio_seek(mtar_t *tar, unsigned offset) {
   int res = fseek(tar->stream, offset, SEEK_SET);
   return (res == 0) ? MTAR_ESUCCESS : MTAR_ESEEKFAIL;
 }
 
-static int file_close(mtar_t *tar) {
+static int mtar_stdio_close(mtar_t *tar) {
   fclose(tar->stream);
   return MTAR_ESUCCESS;
 }
@@ -187,10 +187,10 @@ int mtar_open(mtar_t *tar, const char *filename, const char *mode) {
 
   /* Init tar struct and functions */
   memset(tar, 0, sizeof(*tar));
-  tar->write = file_write;
-  tar->read = file_read;
-  tar->seek = file_seek;
-  tar->close = file_close;
+  tar->write = mtar_stdio_write;
+  tar->read = mtar_stdio_read;
+  tar->seek = mtar_stdio_seek;
+  tar->close = mtar_stdio_close;
 
   /* Assure mode is always binary */
   if ( strchr(mode, 'r') ) mode = "rb";
